{
    "version": "0.2.0",
    "configurations": [
       
        {
            "name": "Launch Chrome to view API",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5050/getUsers",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Attach to Chrome",
            "request": "attach",
            "type": "chrome",
            "port": 9222,
            "webRoot": "${workspaceFolder}"
        }
    ]
}
